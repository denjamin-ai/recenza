{
  "name": "recenza",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:test": "npm run test:reset && dotenv -e .env.test -- next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:migrate:test": "dotenv -e .env.test -- drizzle-kit migrate",
    "seed": "dotenv -e .env.local -- tsx src/lib/db/seed.ts",
    "seed:test": "dotenv -e .env.test -- tsx src/lib/db/seed-test.ts",
    "test:reset": "npm run db:migrate:test && npm run seed:test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report testing/reports/playwright-html",
    "test:smoke": "playwright test --grep @smoke",
    "test:critical": "playwright test --grep @critical"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "iron-session": "^8.0.4",
    "katex": "^0.16.47",
    "mermaid": "^11.16.0",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.2.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/katex": "^0.16.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
