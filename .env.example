# =========================================================================
# Recenza — пример переменных окружения. Скопируй в .env.local и .env.test.
# Реальные значения НЕ коммитить. '$' в значениях (bcrypt-хэши, пароли)
# экранировать как '\$' — иначе dotenv-expand считает '$xxx' переменной.
# =========================================================================

# --- Общие (нужны во всех окружениях) ---
SESSION_SECRET=                 # 32+ случайных символа; без него приложение не стартует
ADMIN_PASSWORD_HASH=            # bcrypt-хэш пароля админа; '$' → '\$' (dotenv-expand)
NEXT_PUBLIC_BASE_URL=http://localhost:3000   # канонический URL (sitemap/RSS/JSON-LD).
                                #   В .env.test поставить http://localhost:3001 (тест-стенд).

# --- Выбор стенда/БД ---
# APP_ENV управляет выбором файловой БД, когда TURSO_* пусты:
#   не задан / любое  → file:blog.db        (dev,  порт 3000)
#   test              → file:blog.test.db   (test, порт 3001) — задаётся ТОЛЬКО в .env.test
APP_ENV=                        # в .env.test: APP_ENV=test ; в .env.local не задавать

# --- База данных ---
# dev/test: TURSO_* не задавать → fallback на file: по APP_ENV (см. выше)
# prod:     обязательны оба значения Turso
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# --- ТОЛЬКО .env.test (никогда в проде!) ---
ADMIN_PASSWORD_PLAIN=           # открытый пароль админа для авто-логина в тестах.
                                #   ДОЛЖЕН соответствовать ADMIN_PASSWORD_HASH (одна пара пароль/хэш).
                                #   По умолчанию в SETUP.md — admin-pass. Если в пароле есть '$' —
                                #   экранировать как '\$' (так же, как хэш).
