# =========================================================================
# Recenza — пример переменных окружения. Скопируй в .env.local и .env.test.
# Реальные значения НЕ коммитить. '$' в bcrypt-хэшах экранировать как '\$'.
# =========================================================================

# --- Общие (нужны во всех окружениях) ---
SESSION_SECRET=                 # 32+ случайных символа; без него приложение не стартует
ADMIN_PASSWORD_HASH=            # bcrypt-хэш пароля админа; '$' → '\$' (dotenv-expand)
NEXT_PUBLIC_BASE_URL=http://localhost:3000   # канонический URL (sitemap/RSS/JSON-LD)

# --- База данных ---
# Механика двух стендов: имя локального файла БД задаётся явно:
#   .env.local → DB_FILE_NAME=blog.db   |   .env.test → DB_FILE_NAME=blog.test.db
# db/index.ts и drizzle.config.ts читают: TURSO_CONNECTION_URL ?? file:${DB_FILE_NAME}
DB_FILE_NAME=blog.db
# prod: оба обязательны (тогда file:-fallback не используется)
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# --- Прод (Vercel) ---
CRON_SECRET=                    # Bearer для /api/cron/publish

# --- ТОЛЬКО .env.test (никогда в проде!) ---
ADMIN_PASSWORD_PLAIN=           # открытый пароль админа для авто-логина в тестах;
                                # ОБЯЗАН соответствовать ADMIN_PASSWORD_HASH этого же файла

# ⚠️ next dev НЕ читает .env.test автоматически — команды тест-стенда
# запускаются через dotenv-cli: dotenv -e .env.test -- <команда>
